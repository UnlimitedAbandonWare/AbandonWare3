#!/bin/sh
ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
if [ -z "$ROOT" ]; then
  exit 0
fi

if command -v pwsh >/dev/null 2>&1; then
  exec pwsh -NoProfile -File "$ROOT/scripts/git_secret_guard.ps1" -Mode pre-push
fi

if command -v powershell.exe >/dev/null 2>&1; then
  exec powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$ROOT/scripts/git_secret_guard.ps1" -Mode pre-push
fi

echo "[AWX][git-guard] BLOCK: PowerShell is required for the secret guard hook." >&2
exit 1
